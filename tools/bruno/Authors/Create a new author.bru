meta {
  name: Create a new author
  type: http
  seq: 2
  tags: [
    Authors
  ]
}

post {
  url: {{baseUrl}}/api/authors
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "",
    "bio": "",
    "website": ""
  }
}

docs {
  Create a new author (admin only)
}

example {
  name: 201 Response
  description: Author created successfully
  
  request: {
    url: {{baseUrl}}/api/authors
    method: POST
    mode: json
    body:json: {
      {
        "name": "",
        "bio": "",
        "website": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: json
      content: '''
        {
          "id": 0,
          "name": "",
          "bio": "",
          "createdAt": "",
          "updatedAt": ""
        }
      '''
    }
  }
}

