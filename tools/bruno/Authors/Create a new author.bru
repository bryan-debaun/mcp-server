    mode: json
    body:json: {
      {
        "name": "",
        "bio": "",
        "website": ""
      }
    }
  }
  
  response: {
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

