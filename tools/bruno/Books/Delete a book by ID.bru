meta {
  name: Delete a book by ID
  type: http
  seq: 5
  tags: [
    Books
  ]
}

delete {
  url: {{baseUrl}}/api/books/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

auth:bearer {
  token: {{token}}
}

docs {
  Delete a book (admin only)
}

example {
  name: 200 Response
  description: Book deleted successfully
  
