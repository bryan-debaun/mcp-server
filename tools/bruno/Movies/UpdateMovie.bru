    "status": ""
  }
}

example {
  name: 200 Response
  description: Movie updated successfully
  
  request: {
    url: {{baseUrl}}/api/movies/:id
    method: PUT
    mode: json
    params:path: {
      id: 
    }
  
    body:json: {
