put {
  url: {{baseUrl}}/api/movies/:id
  body: json
  auth: bearer
}

params:path {
  id: 
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 0,
    "title": "",
    "description": "",
    "iasn": "",
    "imdbId": "",
